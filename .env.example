# Anthropic API key used by both the triage and RCA agents
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model selection (defaults shown)
TRIAGE_MODEL=claude-haiku-4-5-20251001
RCA_MODEL=claude-sonnet-5

# Optional: enables real Slack ingestion (app.ingestion.slack_ingest). If unset,
# the agents' Slack tool falls back to the bundled mock thread data.
SLACK_BOT_TOKEN=

# Postgres (matches docker-compose defaults, override only for local non-docker runs)
POSTGRES_USER=rca
POSTGRES_PASSWORD=rca
POSTGRES_DB=rca
DATABASE_URL=postgresql+psycopg2://rca:rca@db:5432/rca

REDIS_URL=redis://redis:6379/0
