# Anthropic API key used by both the triage and RCA agents
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model selection (defaults shown)
TRIAGE_MODEL=claude-haiku-4-5-20251001
RCA_MODEL=claude-sonnet-5

# Optional: enables real Slack ingestion (app.ingestion.slack_ingest). If unset,
# the agents' Slack tool falls back to the bundled mock thread data.
SLACK_BOT_TOKEN=

# Postgres (matches docker-compose defaults, override only for local non-docker runs)
POSTGRES_USER=rca
POSTGRES_PASSWORD=rca
POSTGRES_DB=rca
DATABASE_URL=postgresql+psycopg2://rca:rca@db:5432/rca

REDIS_URL=redis://redis:6379/0

# Log level for both the API process and the Celery worker: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: enables Sentry error tracking for the API process and the Celery
# worker. Leave blank to disable (default) - nothing is sent anywhere without a DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Fraction of requests/tasks to sample for performance tracing (0.0-1.0)
SENTRY_TRACES_SAMPLE_RATE=0.0

# Optional: Datadog APM tracing (backend + worker are started via `ddtrace-run`,
# see entrypoint.sh). Safe to leave unset - ddtrace just can't reach an agent
# and drops traces, it doesn't affect the app. DD_AGENT_HOST/DD_SERVICE below
# are overridden per-service in docker-compose.yml; these defaults only apply
# if you run the API/worker directly on the host (not via compose).
DD_SERVICE=rca-agent
DD_ENV=development
DD_VERSION=
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_PORT=8126
DD_TRACE_ENABLED=true

# Optional: local Datadog Agent container so the above traces have somewhere
# to go. Not started by default - run `docker compose --profile datadog up`.
# Leave DD_API_KEY blank to just skip it (the Agent container idles unauthenticated).
DD_API_KEY=
DD_SITE=datadoghq.com
